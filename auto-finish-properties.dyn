    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.DB.Architecture import Room\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\ntarget_param_name = IN[0] if IN[0] else \"Comments\"\r\n\r\n# =====================================\r\n# HELPERS\r\n# =====================================\r\ndef get_room_point(room):\r\n    try:\r\n        loc = room.Location\r\n        if loc and hasattr(loc, \"Point\"):\r\n            return loc.Point\r\n    except:\r\n        pass\r\n    return None\r\n\r\ndef get_room_upper_z(room):\r\n    \"\"\"\r\n    Ambil elevasi atas room.\r\n    Prioritas:\r\n    1. base level + Unbounded Height\r\n    2. room point Z + default\r\n    \"\"\"\r\n    try:\r\n        lvl = doc.GetElement(room.LevelId)\r\n        base_z = lvl.Elevation if lvl else 0.0\r\n\r\n        p = room.get_Parameter(BuiltInParameter.ROOM_UPPER_OFFSET)\r\n        upper_offset = p.AsDouble() if p and p.HasValue else None\r\n\r\n        p2 = room.get_Parameter(BuiltInParameter.ROOM_HEIGHT)\r\n        room_height = p2.AsDouble() if p2 and p2.HasValue else None\r\n\r\n        if room_height is not None:\r\n            return base_z + room_height\r\n        elif upper_offset is not None:\r\n            return base_z + upper_offset\r\n    except:\r\n        pass\r\n\r\n    pt = get_room_point(room)\r\n    if pt:\r\n        return pt.Z + 10.0\r\n\r\n    return None\r\n\r\ndef get_material_name(mat_id):\r\n    try:\r\n        if mat_id and mat_id != ElementId.InvalidElementId:\r\n            mat = doc.GetElement(mat_id)\r\n            if mat and mat.Name:\r\n                return mat.Name\r\n    except:\r\n        pass\r\n    return None\r\n\r\ndef point_inside_bbox_xy(point, bbox, tol=0.5):\r\n    if point is None or bbox is None:\r\n        return False\r\n    return (\r\n        bbox.Min.X - tol <= point.X <= bbox.Max.X + tol and\r\n        bbox.Min.Y - tol <= point.Y <= bbox.Max.Y + tol\r\n    )\r\n\r\ndef get_ceiling_reference_z(ceiling):\r\n    \"\"\"\r\n    Ambil elevasi referensi ceiling.\r\n    Prioritas:\r\n    1. level elevation + height above level\r\n    2. bbox min z\r\n    \"\"\"\r\n    try:\r\n        lvl = doc.GetElement(ceiling.LevelId)\r\n        lvl_z = lvl.Elevation if lvl else 0.0\r\n\r\n        p = ceiling.get_Parameter(BuiltInParameter.CEILING_HEIGHTABOVELEVEL_PARAM)\r\n        h = p.AsDouble() if p and p.HasValue else 0.0\r\n\r\n        return lvl_z + h\r\n    except:\r\n        pass\r\n\r\n    try:\r\n        bbox = ceiling.get_BoundingBox(None)\r\n        if bbox:\r\n            return bbox.Min.Z\r\n    except:\r\n        pass\r\n\r\n    return None\r\n\r\ndef get_bottom_finish_material_name(ceiling):\r\n    \"\"\"\r\n    Ambil material sisi bawah ceiling.\r\n    Prioritas:\r\n    1. shell layer sisi interior\r\n    2. fallback layer terakhir yang punya material\r\n    3. fallback material ids\r\n    \"\"\"\r\n    try:\r\n        ct = doc.GetElement(ceiling.GetTypeId())\r\n        if ct is None:\r\n            return None\r\n\r\n        cs = ct.GetCompoundStructure()\r\n        if cs is None:\r\n            return None\r\n\r\n        layers = list(cs.GetLayers())\r\n        if not layers or len(layers) == 0:\r\n            return None\r\n\r\n        # Untuk ceiling, sisi bawah yang menghadap room biasanya sisi interior\r\n        try:\r\n            int_count = cs.GetNumberOfShellLayers(ShellLayerType.Interior)\r\n        except:\r\n            int_count = 0\r\n\r\n        if int_count > 0:\r\n            start_index = len(layers) - int_count\r\n            for i in range(start_index, len(layers)):\r\n                mat_name = get_material_name(layers[i].MaterialId)\r\n                if mat_name:\r\n                    return mat_name\r\n\r\n        # fallback: ambil layer terakhir yang punya material\r\n        for i in range(len(layers) - 1, -1, -1):\r\n            mat_name = get_material_name(layers[i].MaterialId)\r\n            if mat_name:\r\n                return mat_name\r\n\r\n    except:\r\n        pass\r\n\r\n    # fallback terakhir\r\n    try:\r\n        mat_ids = ceiling.GetMaterialIds(False)\r\n        if mat_ids and mat_ids.Count > 0:\r\n            for mat_id in mat_ids:\r\n                mat_name = get_material_name(mat_id)\r\n                if mat_name:\r\n                    return mat_name\r\n    except:\r\n        pass\r\n\r\n    return None\r\n\r\ndef get_best_ceiling_for_room(room, ceilings):\r\n    room_pt = get_room_point(room)\r\n    room_top_z = get_room_upper_z(room)\r\n\r\n    if room_pt is None:\r\n        return None, \"No room point\"\r\n\r\n    candidates = []\r\n\r\n    for ceiling in ceilings:\r\n        try:\r\n            bbox = ceiling.get_BoundingBox(None)\r\n            if bbox is None:\r\n                continue\r\n\r\n            if not point_inside_bbox_xy(room_pt, bbox, tol=1.0):\r\n                continue\r\n\r\n            ceil_z = get_ceiling_reference_z(ceiling)\r\n            if ceil_z is None:\r\n                continue\r\n\r\n            # ceiling harus di atas atau dekat atas room\r\n            dz = abs(ceil_z - room_top_z) if room_top_z is not None else 999999\r\n            candidates.append((dz, ceil_z, ceiling))\r\n        except:\r\n            pass\r\n\r\n    if not candidates:\r\n        return None, \"No candidate ceiling\"\r\n\r\n    candidates.sort(key=lambda x: x[0])\r\n    return candidates[0][2], \"OK\"\r\n\r\ndef set_room_text_parameter(room, param_name, value):\r\n    try:\r\n        p = room.LookupParameter(param_name)\r\n        if not p:\r\n            return False, \"Parameter not found\"\r\n        if p.IsReadOnly:\r\n            return False, \"Parameter read-only\"\r\n        if p.StorageType != StorageType.String:\r\n            return False, \"Parameter not text\"\r\n        p.Set(value)\r\n        return True, \"OK\"\r\n    except Exception as e:\r\n        return False, str(e)\r\n\r\n# =====================================\r\n# COLLECT\r\n# =====================================\r\nrooms = FilteredElementCollector(doc) \\\r\n    .OfCategory(BuiltInCategory.OST_Rooms) \\\r\n    .WhereElementIsNotElementType() \\\r\n    .ToElements()\r\n\r\nceilings = FilteredElementCollector(doc) \\\r\n    .OfCategory(BuiltInCategory.OST_Ceilings) \\\r\n    .WhereElementIsNotElementType() \\\r\n    .ToElements()\r\n\r\nprocessed = []\r\nskipped = []\r\nfailed = []\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nfor room in rooms:\r\n    try:\r\n        if room.Area <= 0:\r\n            skipped.append(\"Room {} skipped (area=0)\".format(room.Id.IntegerValue))\r\n            continue\r\n\r\n        room_name = \"\"\r\n        try:\r\n            room_name = room.LookupParameter(\"Name\").AsString()\r\n        except:\r\n            room_name = \"\"\r\n\r\n        ceiling, status = get_best_ceiling_for_room(room, ceilings)\r\n        if ceiling is None:\r\n            failed.append(\"Room {} [{}]: {}\".format(room.Id.IntegerValue, room_name, status))\r\n            continue\r\n\r\n        mat_name = get_bottom_finish_material_name(ceiling)\r\n        if not mat_name:\r\n            failed.append(\"Room {} [{}]: no ceiling finish material found\".format(room.Id.IntegerValue, room_name))\r\n            continue\r\n\r\n        ok, msg = set_room_text_parameter(room, target_param_name, mat_name)\r\n        if ok:\r\n            processed.append(\"Room {} [{}] -> {}\".format(room.Id.IntegerValue, room_name, mat_name))\r\n        else:\r\n            failed.append(\"Room {} [{}]: {}\".format(room.Id.IntegerValue, room_name, msg))\r\n\r\n    except Exception as e:\r\n        failed.append(\"Room {}: {}\".format(room.Id.IntegerValue, str(e)))\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = processed, skipped, failed",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "770bae9ed52041a9b51efc1ca84fecaa",
      "NodeType": "PythonScriptNode",
