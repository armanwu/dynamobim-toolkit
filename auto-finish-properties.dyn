      "Code": "\"Wall Finish\";"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.DB.Architecture import Room\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\ntarget_param_name = IN[0] if IN[0] else \"Comments\"\r\n\r\n# =====================================\r\n# HELPERS\r\n# =====================================\r\ndef get_room_point(room):\r\n    try:\r\n        loc = room.Location\r\n        if loc and hasattr(loc, \"Point\"):\r\n            return loc.Point\r\n    except:\r\n        pass\r\n    return None\r\n\r\ndef get_room_level_elevation(room):\r\n    try:\r\n        lvl = doc.GetElement(room.LevelId)\r\n        if lvl:\r\n            return lvl.Elevation\r\n    except:\r\n        pass\r\n    return None\r\n\r\ndef get_material_name(mat_id):\r\n    try:\r\n        if mat_id and mat_id != ElementId.InvalidElementId:\r\n            mat = doc.GetElement(mat_id)\r\n            if mat and mat.Name:\r\n                return mat.Name\r\n    except:\r\n        pass\r\n    return None\r\n\r\ndef point_inside_bbox_xy(point, bbox, tol=0.5):\r\n    if point is None or bbox is None:\r\n        return False\r\n    return (\r\n        bbox.Min.X - tol <= point.X <= bbox.Max.X + tol and\r\n        bbox.Min.Y - tol <= point.Y <= bbox.Max.Y + tol\r\n    )\r\n\r\ndef get_floor_reference_z(floor):\r\n    # pakai level + height above level jika ada\r\n    try:\r\n        lvl = doc.GetElement(floor.LevelId)\r\n        lvl_z = lvl.Elevation if lvl else 0.0\r\n\r\n        p = floor.get_Parameter(BuiltInParameter.FLOOR_HEIGHTABOVELEVEL_PARAM)\r\n        h = p.AsDouble() if p and p.HasValue else 0.0\r\n\r\n        return lvl_z + h\r\n    except:\r\n        pass\r\n\r\n    # fallback bbox\r\n    try:\r\n        bbox = floor.get_BoundingBox(None)\r\n        if bbox:\r\n            return bbox.Max.Z\r\n    except:\r\n        pass\r\n\r\n    return None\r\n\r\ndef get_top_finish_material_name(floor):\r\n    \"\"\"\r\n    Ambil material finish sisi atas floor.\r\n    Prioritas:\r\n    1. shell layer sisi Exterior (umumnya sisi atas floor)\r\n    2. fallback layer awal yang punya material\r\n    3. fallback material ids\r\n    \"\"\"\r\n    try:\r\n        ft = doc.GetElement(floor.GetTypeId())\r\n        if ft is None:\r\n            return None\r\n\r\n        cs = ft.GetCompoundStructure()\r\n        if cs is None:\r\n            return None\r\n\r\n        layers = list(cs.GetLayers())\r\n        if not layers or len(layers) == 0:\r\n            return None\r\n\r\n        # coba shell layer sisi atas / exterior\r\n        try:\r\n            ext_count = cs.GetNumberOfShellLayers(ShellLayerType.Exterior)\r\n        except:\r\n            ext_count = 0\r\n\r\n        if ext_count > 0:\r\n            for i in range(ext_count):\r\n                mat_name = get_material_name(layers[i].MaterialId)\r\n                if mat_name:\r\n                    return mat_name\r\n\r\n        # fallback: ambil layer pertama yang punya material\r\n        for layer in layers:\r\n            mat_name = get_material_name(layer.MaterialId)\r\n            if mat_name:\r\n                return mat_name\r\n\r\n    except:\r\n        pass\r\n\r\n    # fallback terakhir\r\n    try:\r\n        mat_ids = floor.GetMaterialIds(False)\r\n        if mat_ids and mat_ids.Count > 0:\r\n            for mat_id in mat_ids:\r\n                mat_name = get_material_name(mat_id)\r\n                if mat_name:\r\n                    return mat_name\r\n    except:\r\n        pass\r\n\r\n    return None\r\n\r\ndef get_best_floor_for_room(room, floors):\r\n    room_pt = get_room_point(room)\r\n    room_lvl_z = get_room_level_elevation(room)\r\n\r\n    if room_pt is None:\r\n        return None, \"No room point\"\r\n\r\n    candidates = []\r\n\r\n    for floor in floors:\r\n        try:\r\n            bbox = floor.get_BoundingBox(None)\r\n            if bbox is None:\r\n                continue\r\n\r\n            if not point_inside_bbox_xy(room_pt, bbox, tol=1.0):\r\n                continue\r\n\r\n            floor_z = get_floor_reference_z(floor)\r\n            if floor_z is None:\r\n                continue\r\n\r\n            # cari yang paling dekat dengan level room\r\n            dz = abs(floor_z - room_lvl_z) if room_lvl_z is not None else 999999\r\n            candidates.append((dz, floor))\r\n        except:\r\n            pass\r\n\r\n    if not candidates:\r\n        return None, \"No candidate floor\"\r\n\r\n    candidates.sort(key=lambda x: x[0])\r\n    return candidates[0][1], \"OK\"\r\n\r\ndef set_room_text_parameter(room, param_name, value):\r\n    try:\r\n        p = room.LookupParameter(param_name)\r\n        if not p:\r\n            return False, \"Parameter not found\"\r\n        if p.IsReadOnly:\r\n            return False, \"Parameter read-only\"\r\n        if p.StorageType != StorageType.String:\r\n            return False, \"Parameter not text\"\r\n        p.Set(value)\r\n        return True, \"OK\"\r\n    except Exception as e:\r\n        return False, str(e)\r\n\r\n# =====================================\r\n# COLLECT\r\n# =====================================\r\nrooms = FilteredElementCollector(doc) \\\r\n    .OfCategory(BuiltInCategory.OST_Rooms) \\\r\n    .WhereElementIsNotElementType() \\\r\n    .ToElements()\r\n\r\nfloors = FilteredElementCollector(doc) \\\r\n    .OfClass(Floor) \\\r\n    .WhereElementIsNotElementType() \\\r\n    .ToElements()\r\n\r\nprocessed = []\r\nskipped = []\r\nfailed = []\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nfor room in rooms:\r\n    try:\r\n        if room.Area <= 0:\r\n            skipped.append(\"Room {} skipped (area=0)\".format(room.Id.IntegerValue))\r\n            continue\r\n\r\n        room_name = \"\"\r\n        try:\r\n            room_name = room.LookupParameter(\"Name\").AsString()\r\n        except:\r\n            room_name = \"\"\r\n\r\n        floor, status = get_best_floor_for_room(room, floors)\r\n        if floor is None:\r\n            failed.append(\"Room {} [{}]: {}\".format(room.Id.IntegerValue, room_name, status))\r\n            continue\r\n\r\n        mat_name = get_top_finish_material_name(floor)\r\n        if not mat_name:\r\n            failed.append(\"Room {} [{}]: no top finish material found\".format(room.Id.IntegerValue, room_name))\r\n            continue\r\n\r\n        ok, msg = set_room_text_parameter(room, target_param_name, mat_name)\r\n        if ok:\r\n            processed.append(\"Room {} [{}] -> {}\".format(room.Id.IntegerValue, room_name, mat_name))\r\n        else:\r\n            failed.append(\"Room {} [{}]: {}\".format(room.Id.IntegerValue, room_name, msg))\r\n\r\n    except Exception as e:\r\n        failed.append(\"Room {}: {}\".format(room.Id.IntegerValue, str(e)))\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = processed, skipped, failed",
