  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nimport math\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.DB.Architecture import Room\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\ntarget_param_name = IN[0] if IN[0] else \"Comments\"\r\n\r\n# =====================================\r\n# HELPERS\r\n# =====================================\r\ndef get_room_point(room):\r\n    try:\r\n        loc = room.Location\r\n        if loc and hasattr(loc, \"Point\"):\r\n            return loc.Point\r\n    except:\r\n        pass\r\n    return None\r\n\r\ndef get_material_name(mat_id):\r\n    try:\r\n        if mat_id and mat_id != ElementId.InvalidElementId:\r\n            mat = doc.GetElement(mat_id)\r\n            if mat and mat.Name:\r\n                return mat.Name\r\n    except:\r\n        pass\r\n    return None\r\n\r\ndef normalize_xyz(v):\r\n    try:\r\n        l = math.sqrt(v.X*v.X + v.Y*v.Y + v.Z*v.Z)\r\n        if l == 0:\r\n            return None\r\n        return XYZ(v.X/l, v.Y/l, v.Z/l)\r\n    except:\r\n        return None\r\n\r\ndef dot_xyz(a, b):\r\n    return a.X*b.X + a.Y*b.Y + a.Z*b.Z\r\n\r\ndef get_wall_midpoint(wall):\r\n    try:\r\n        c = wall.Location.Curve\r\n        return c.Evaluate(0.5, True)\r\n    except:\r\n        try:\r\n            c = wall.Curve\r\n            return c.Evaluate(0.5, True)\r\n        except:\r\n            return None\r\n\r\ndef get_room_facing_side(wall, room_point):\r\n    \"\"\"\r\n    Tentukan room berada di sisi Interior atau Exterior wall.\r\n    Wall.Orientation dianggap mengarah ke sisi exterior wall.\r\n    Jika vektor dari midpoint wall ke titik room searah orientation,\r\n    berarti room ada di sisi exterior.\r\n    Kalau berlawanan, room ada di sisi interior.\r\n    \"\"\"\r\n    try:\r\n        wall_mid = get_wall_midpoint(wall)\r\n        if wall_mid is None or room_point is None:\r\n            return None\r\n\r\n        orient = normalize_xyz(wall.Orientation)\r\n        if orient is None:\r\n            return None\r\n\r\n        vec_to_room = XYZ(\r\n            room_point.X - wall_mid.X,\r\n            room_point.Y - wall_mid.Y,\r\n            0\r\n        )\r\n        vec_to_room = normalize_xyz(vec_to_room)\r\n        if vec_to_room is None:\r\n            return None\r\n\r\n        d = dot_xyz(orient, vec_to_room)\r\n\r\n        if d >= 0:\r\n            return ShellLayerType.Exterior\r\n        else:\r\n            return ShellLayerType.Interior\r\n    except:\r\n        return None\r\n\r\ndef get_finish_material_from_room_side(wall, room_point):\r\n    \"\"\"\r\n    Ambil material dari shell layer sisi wall yang menghadap room.\r\n    Prioritas:\r\n    1. shell side yang menghadap room\r\n    2. ambil layer shell terluar pada sisi tersebut\r\n    \"\"\"\r\n    try:\r\n        wt = doc.GetElement(wall.GetTypeId())\r\n        if wt is None:\r\n            return None\r\n\r\n        cs = wt.GetCompoundStructure()\r\n        if cs is None:\r\n            return None\r\n\r\n        layers = list(cs.GetLayers())\r\n        if not layers or len(layers) == 0:\r\n            return None\r\n\r\n        room_side = get_room_facing_side(wall, room_point)\r\n        if room_side is None:\r\n            return None\r\n\r\n        ext_count = 0\r\n        int_count = 0\r\n\r\n        try:\r\n            ext_count = cs.GetNumberOfShellLayers(ShellLayerType.Exterior)\r\n        except:\r\n            ext_count = 0\r\n\r\n        try:\r\n            int_count = cs.GetNumberOfShellLayers(ShellLayerType.Interior)\r\n        except:\r\n            int_count = 0\r\n\r\n        # Jika room menghadap sisi exterior, ambil shell exterior terluar\r\n        if room_side == ShellLayerType.Exterior:\r\n            if ext_count > 0:\r\n                for i in range(ext_count):\r\n                    name = get_material_name(layers[i].MaterialId)\r\n                    if name:\r\n                        return name\r\n\r\n        # Jika room menghadap sisi interior, ambil shell interior terluar\r\n        elif room_side == ShellLayerType.Interior:\r\n            if int_count > 0:\r\n                start_index = len(layers) - int_count\r\n                for i in range(start_index, len(layers)):\r\n                    name = get_material_name(layers[i].MaterialId)\r\n                    if name:\r\n                        return name\r\n\r\n        # fallback: cari material pertama saja\r\n        for layer in layers:\r\n            name = get_material_name(layer.MaterialId)\r\n            if name:\r\n                return name\r\n\r\n    except:\r\n        pass\r\n\r\n    return None\r\n\r\ndef get_boundary_walls(room):\r\n    walls = []\r\n    try:\r\n        opts = SpatialElementBoundaryOptions()\r\n        loops = room.GetBoundarySegments(opts)\r\n\r\n        if loops:\r\n            for loop in loops:\r\n                for seg in loop:\r\n                    elem_id = seg.ElementId\r\n                    if elem_id and elem_id != ElementId.InvalidElementId:\r\n                        elem = doc.GetElement(elem_id)\r\n                        if isinstance(elem, Wall):\r\n                            if elem.Id.IntegerValue not in [w.Id.IntegerValue for w in walls]:\r\n                                walls.append(elem)\r\n    except:\r\n        pass\r\n    return walls\r\n\r\ndef set_room_text_parameter(room, param_name, value):\r\n    try:\r\n        p = room.LookupParameter(param_name)\r\n        if p and not p.IsReadOnly and p.StorageType == StorageType.String:\r\n            p.Set(value)\r\n            return True\r\n    except:\r\n        pass\r\n    return False\r\n\r\n# =====================================\r\n# COLLECT ROOMS\r\n# =====================================\r\nrooms = FilteredElementCollector(doc) \\\r\n    .OfCategory(BuiltInCategory.OST_Rooms) \\\r\n    .WhereElementIsNotElementType() \\\r\n    .ToElements()\r\n\r\nprocessed = []\r\nskipped = []\r\nfailed = []\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nfor room in rooms:\r\n    try:\r\n        try:\r\n            if room.Area <= 0:\r\n                skipped.append(\"Room {} skipped (area=0)\".format(room.Id.IntegerValue))\r\n                continue\r\n        except:\r\n            pass\r\n\r\n        room_point = get_room_point(room)\r\n        if room_point is None:\r\n            failed.append(\"Room {}: no room location point\".format(room.Id.IntegerValue))\r\n            continue\r\n\r\n        boundary_walls = get_boundary_walls(room)\r\n        if not boundary_walls:\r\n            failed.append(\"Room {}: no boundary walls found\".format(room.Id.IntegerValue))\r\n            continue\r\n\r\n        finish_names = []\r\n\r\n        for wall in boundary_walls:\r\n            mat_name = get_finish_material_from_room_side(wall, room_point)\r\n            if mat_name and mat_name not in finish_names:\r\n                finish_names.append(mat_name)\r\n\r\n        if not finish_names:\r\n            failed.append(\"Room {}: no room-side wall finish found\".format(room.Id.IntegerValue))\r\n            continue\r\n\r\n        finish_text = \", \".join(finish_names)\r\n\r\n        ok = set_room_text_parameter(room, target_param_name, finish_text)\r\n\r\n        room_name = \"\"\r\n        try:\r\n            room_name = room.LookupParameter(\"Name\").AsString()\r\n        except:\r\n            room_name = \"\"\r\n\r\n        if ok:\r\n            processed.append(\"Room {} [{}] -> {}\".format(\r\n                room.Id.IntegerValue, room_name, finish_text\r\n            ))\r\n        else:\r\n            failed.append(\"Room {}: parameter '{}' not writable/text\".format(\r\n                room.Id.IntegerValue, target_param_name\r\n            ))\r\n\r\n    except Exception as e:\r\n        failed.append(\"Room {}: {}\".format(room.Id.IntegerValue, str(e)))\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = processed, skipped, failedOUT = processed, skipped, failedOUT = processed, skipped, failed",
      "Engine": "CPython3",
