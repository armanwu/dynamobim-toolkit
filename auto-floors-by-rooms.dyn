{
  "Uuid": "8bad1221-1ee3-41c2-80cd-9f9f65dffdc8",
  "IsCustomNode": false,
  "Description": "",
  "Name": "auto-floors-by-rooms",
  "ElementResolver": {
    "ResolutionMap": {}
  },
  "Inputs": [
    {
      "Id": "02438ee264524be3afe188840a7122ed",
      "Name": "Floor Types",
      "Type": "selection",
      "Type2": "dropdownSelection",
      "Value": "Standard Timber-Wood Finish",
