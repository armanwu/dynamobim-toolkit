  "Outputs": [],
  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.DB.Architecture import Room\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# =========================\r\n# INPUT\r\n# =========================\r\nrooms_input = IN[0]\r\nfloor_type = UnwrapElement(IN[1])\r\noffset = IN[2] if IN[2] else 0.0\r\nis_structural = IN[3] if IN[3] is not None else False\r\n\r\n# Pastikan input room menjadi list\r\nif not isinstance(rooms_input, list):\r\n    rooms = [UnwrapElement(rooms_input)]\r\nelse:\r\n    rooms = [UnwrapElement(r) for r in rooms_input]\r\n\r\n# =========================\r\n# HELPER\r\n# =========================\r\ndef get_room_boundary_loops(room):\r\n    \"\"\"\r\n    Mengambil boundary room dan mengubahnya menjadi list of CurveLoop.\r\n    Satu room bisa punya lebih dari satu loop.\r\n    \"\"\"\r\n    opts = SpatialElementBoundaryOptions()\r\n    segments_lists = room.GetBoundarySegments(opts)\r\n\r\n    if not segments_lists:\r\n        return None\r\n\r\n    curve_loops = []\r\n\r\n    for seg_list in segments_lists:\r\n        curve_loop = CurveLoop()\r\n        has_curve = False\r\n\r\n        for seg in seg_list:\r\n            c = seg.GetCurve()\r\n            if c:\r\n                curve_loop.Append(c)\r\n                has_curve = True\r\n\r\n        if has_curve:\r\n            curve_loops.append(curve_loop)\r\n\r\n    return curve_loops if curve_loops else None\r\n\r\n\r\ndef set_floor_offset(floor, offset_value):\r\n    \"\"\"\r\n    Set parameter height above level jika tersedia.\r\n    \"\"\"\r\n    p = floor.get_Parameter(BuiltInParameter.FLOOR_HEIGHTABOVELEVEL_PARAM)\r\n    if p and not p.IsReadOnly:\r\n        p.Set(offset_value)\r\n\r\n\r\ndef valid_room(room):\r\n    \"\"\"\r\n    Cek room valid:\r\n    - objek ada\r\n    - area > 0\r\n    - punya level\r\n    \"\"\"\r\n    if room is None:\r\n        return False, \"Room is None\"\r\n\r\n    try:\r\n        if room.Area <= 0:\r\n            return False, \"Room area <= 0\"\r\n    except:\r\n        return False, \"Cannot read room area\"\r\n\r\n    try:\r\n        lvl_id = room.LevelId\r\n        if lvl_id == ElementId.InvalidElementId:\r\n            return False, \"Invalid LevelId\"\r\n    except:\r\n        return False, \"Cannot read room level\"\r\n\r\n    return True, \"\"\r\n\r\n\r\n# =========================\r\n# MAIN\r\n# =========================\r\ncreated_floors = []\r\nfailed_rooms = []\r\nlog = []\r\n\r\nif floor_type is None:\r\n    OUT = ([], [\"FloorType input is null\"], [\"No floor created\"])\r\nelse:\r\n    TransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\n    for room in rooms:\r\n        try:\r\n            ok, msg = valid_room(room)\r\n            if not ok:\r\n                failed_rooms.append(room)\r\n                log.append(\"FAILED - Room [{}]: {}\".format(room.Id.IntegerValue if room else \"None\", msg))\r\n                continue\r\n\r\n            loops = get_room_boundary_loops(room)\r\n            if not loops:\r\n                failed_rooms.append(room)\r\n                log.append(\"FAILED - Room [{}]: No valid boundary loops\".format(room.Id.IntegerValue))\r\n                continue\r\n\r\n            level_id = room.LevelId\r\n\r\n            # Membuat floor dari boundary room\r\n            new_floor = Floor.Create(\r\n                doc,\r\n                loops,\r\n                floor_type.Id,\r\n                level_id,\r\n                is_structural,\r\n                None,\r\n                0.0\r\n            )\r\n\r\n            # Set offset setelah floor dibuat\r\n            if new_floor:\r\n                set_floor_offset(new_floor, offset)\r\n                created_floors.append(new_floor)\r\n                log.append(\"SUCCESS - Room [{}] -> Floor [{}]\".format(\r\n                    room.Id.IntegerValue,\r\n                    new_floor.Id.IntegerValue\r\n                ))\r\n            else:\r\n                failed_rooms.append(room)\r\n                log.append(\"FAILED - Room [{}]: Floor.Create returned null\".format(room.Id.IntegerValue))\r\n\r\n        except Exception as e:\r\n            failed_rooms.append(room)\r\n            try:\r\n                rid = room.Id.IntegerValue\r\n            except:\r\n                rid = \"Unknown\"\r\n            log.append(\"FAILED - Room [{}]: {}\".format(rid, str(e)))\r\n\r\n    TransactionManager.Instance.TransactionTaskDone()\r\n\r\n    OUT = (created_floors, failed_rooms, log)",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "5eae8de5a2ff4a3c95ed4fc5b5e02416",
      "NodeType": "PythonScriptNode",
